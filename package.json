{
  "name": "@feedjar/sdk-react-native",
  "version": "0.1.0",
  "description": "FeedJar React Native SDK — configure, submit, and built-in feedback UI (parity with iOS FeedJarKit).",
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "react-native": "./src/index.ts",
  "exports": {
    ".": {
      "react-native": "./src/index.ts",
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "files": ["dist", "src", "LICENSE", "README.md", "CHANGELOG.md"],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/feedjar/feedjar-sdk-reactnative.git"
  },
  "bugs": {
    "url": "https://github.com/feedjar/feedjar-sdk-reactnative/issues"
  },
  "homepage": "https://feedjar.in/docs/react-native-sdk",
  "publishConfig": {
    "access": "public"
  },
  "scripts": {
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "test": "vitest run",
    "prepublishOnly": "npm run build"
  },
  "peerDependencies": {
    "react": ">=18",
    "react-native": ">=0.71"
  },
  "devDependencies": {
    "@types/react": "^19.0.0",
    "react": "^19.0.0",
    "react-native": "^0.79.0",
    "typescript": "^5.6.3",
    "vitest": "^3.0.0"
  }
}
